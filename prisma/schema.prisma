generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  totpSecret   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  order     Int       @default(0)
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  summary     String
  body        String         @default("")
  coverUrl    String
  liveUrl     String?
  repoUrl     String?
  techStack   String         @default("")
  order       Int            @default(0)
  featured    Boolean        @default(false)
  published   Boolean        @default(true)

  // status: "live" | "wip" | "archived" | "oss"
  status      String         @default("live")

  // case study (only used when hasCaseStudy = true)
  hasCaseStudy        Boolean @default(false)
  caseChallenge       String  @default("")
  caseProcess         String  @default("")
  caseOutcome         String  @default("")
  caseLessons         String  @default("")

  // before/after pair for 3D-style projects (optional)
  beforeUrl   String?
  afterUrl    String?

  /// Optional display date (e.g. "shipped on") — falls back to createdAt
  /// in the UI when null. Lets the owner backdate or override the date.
  displayDate DateTime?

  viewCount   Int            @default(200)

  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images      ProjectImage[]
  homeSections HomeSection[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

/// Standalone gallery (separate from per-project images).
model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String   @default("")
  caption   String   @default("")
  order     Int      @default(0)
  width     Int?
  height    Int?
  takenAt   DateTime?
  createdAt DateTime @default(now())
}

/// Storefront customer accounts. Separate from AdminUser — the admin is
/// the owner of the site, customers are buyers.
model Customer {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("")
  /// Optional socials — surfaced in chat as contact info so the admin
  /// always has a way to reach back beyond email.
  twitter      String   @default("")
  github       String   @default("")
  linkedin     String   @default("")
  website      String   @default("")
  /// Plain hex sha256 token + ISO expiry for password reset (set when
  /// requesting reset, cleared on use).
  resetToken     String?
  resetExpiresAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

/// A digital product for sale on /store. Price stored in minor units
/// (öre / cents) to avoid float rounding.
model StoreProduct {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String   @default("")
  description String   @default("")
  /// "game" | "asset" | "program" | "other"
  category    String   @default("other")
  price       Int      @default(0)
  currency    String   @default("SEK")
  coverUrl    String   @default("")
  /// Path to the downloadable file under public/uploads/store/.
  fileUrl     String   @default("")
  fileSize    Int      @default(0)
  fileName    String   @default("")
  /// Optional links to external storefronts (Gumroad / Itch.io / Steam).
  externalUrl String?
  published   Boolean  @default(true)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  items        OrderItem[]
  homeSections HomeSection[]
}

model Order {
  id                  String      @id @default(cuid())
  customerId          String
  customer            Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  /// Total in minor units, includes tax if Stripe Tax is enabled.
  totalAmount         Int
  currency            String      @default("SEK")
  /// "pending" | "paid" | "failed" | "refunded"
  status              String      @default("pending")
  /// True when admin gifted this order (vs. real Stripe purchase).
  isGift              Boolean     @default(false)
  /// Optional message from admin attached to a gifted order.
  giftNote            String      @default("")
  /// Customer-side notification flag — set when a gift is created,
  /// cleared once the customer opens the order detail.
  notifyCustomer      Boolean     @default(false)
  stripeSessionId     String?     @unique
  stripePaymentIntent String?
  paidAt              DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  items               OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([customerId, notifyCustomer])
}

model OrderItem {
  id              String       @id @default(cuid())
  orderId         String
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         StoreProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  /// Snapshot of the product price at purchase time.
  priceAtPurchase Int
  /// Snapshot of file URL at purchase — survives if owner later renames.
  fileUrlSnapshot String       @default("")
  fileNameSnapshot String      @default("")
  downloadCount   Int          @default(0)
  createdAt       DateTime     @default(now())

  @@index([orderId])
  @@index([productId])
}

/// Stripe configuration. Secret + webhook secret are AES-GCM encrypted with
/// a key derived from AUTH_SECRET, so a leaked database alone doesn't
/// expose payment credentials.
model StripeSettings {
  id                       String   @id @default("singleton")
  enabled                  Boolean  @default(false)
  /// "test" | "live"
  mode                     String   @default("test")
  publishableKey           String   @default("")
  encryptedSecretKey       String   @default("")
  encryptedWebhookSecret   String   @default("")
  /// Where customers land after a successful checkout (relative path).
  successPath              String   @default("/store/checkout/success")
  /// Where customers land if they cancel (relative path).
  cancelPath               String   @default("/store")
  updatedAt                DateTime @updatedAt @default(now())
}

/// Append-only audit trail of admin actions for the activity feed.
model ActivityLog {
  id         String   @id @default(cuid())
  action     String   // e.g. "project.create", "message.delete", "site.update"
  entityType String?  // "project" | "message" | "section" | ...
  entityId   String?
  label      String   @default("") // human-readable label for the entity
  createdAt  DateTime @default(now())
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  alt       String  @default("")
  order     Int     @default(0)
  createdAt DateTime @default(now())
}

model AboutMe {
  id              String   @id @default("singleton")
  name            String   @default("David Rajala")
  role            String   @default("Full Stack Developer")
  avatarUrl       String   @default("")
  bio             String   @default("")
  location        String   @default("Göteborg, Sverige")
  email           String   @default("")
  phone           String   @default("")
  yearsExp        Int      @default(0)
  projectsDone    Int      @default(0)
  clients         Int      @default(0)
  skills          String   @default("")
  available       Boolean  @default(true)
  busyMessage     String   @default("Arbetar med pågående projekt — väntetid kan ske")
  heroBgUrl       String   @default("")
  heroBgType      String   @default("")
  updatedAt       DateTime @updatedAt @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String   @default("")
  message   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
  saved     Boolean  @default(false)
  /// "customer" (default — message sent by visitor) | "admin" (reply from owner)
  senderType String  @default("customer")
  /// Stable per-conversation key — by default the customer email lowercased.
  /// Lets us group messages into threads even before customer accounts existed.
  threadKey String   @default("")
  contacts  ContactDetail[]

  @@index([threadKey, createdAt])
}

model ContactDetail {
  id        String   @id @default(cuid())
  messageId String
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type      String
  value     String
  label     String   @default("")
  createdAt DateTime @default(now())
}

model NotificationSettings {
  id              String   @id @default("singleton")
  telegramEnabled Boolean  @default(false)
  telegramToken   String   @default("")
  telegramChatId  String   @default("")
  updatedAt       DateTime @updatedAt @default(now())
}

/// One row per renderable home-page section. Copy fields are nullable —
/// null means "use the component's hardcoded default", so the site renders
/// fine even when the table is empty.
/// Multiple rows per `type` are allowed — a "featured" section can be
/// duplicated to spotlight several projects. `projectId` is set on
/// featured sections to bind a specific project; otherwise null.
model HomeSection {
  id             String        @id @default(cuid())
  type           String
  order          Int           @default(0)
  visible        Boolean       @default(true)
  eyebrow        String?
  title          String?
  titleMuted     String?
  body           String?
  ctaLabel       String?
  ctaHref        String?
  /// Used by `featured` sections to bind a Project to spotlight.
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// Used by `store-featured` sections to bind a StoreProduct to spotlight.
  storeProductId String?
  storeProduct   StoreProduct? @relation(fields: [storeProductId], references: [id], onDelete: SetNull)
  updatedAt      DateTime      @updatedAt @default(now())
}

/// Site-wide settings (theme, footer copy, hero subline). Singleton.
model SiteSettings {
  id               String   @id @default("singleton")
  accentColor      String   @default("#00e5ff")
  accentColor2     String   @default("#7df9ff")
  footerTagline    String   @default("Building digital products that feel as good as they look.")
  footerCopyright  String   @default("")
  footerStatusText String   @default("SYSTEM ONLINE")
  heroSubline      String   @default("Building digital products with a focus on usability and modern tech. Based in {location}.")
  updatedAt        DateTime @updatedAt @default(now())
}
